#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def active_storage_tables_installed?
  Dir["db/migrate/*_create_active_storage_tables*"].any? ||
    File.read("db/schema.rb").include?("create_table \"active_storage_blobs\"")
end

FileUtils.chdir(APP_ROOT) do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Building Tailwind CSS =="
  system! "bin/rails tailwindcss:build"
  system! "bin/rails assets:verify"

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")
  system! "bin/rails parallel:prepare" if ENV["RAILS_ENV"] == "test" || ARGV.include?("--prepare-test")

  if ENV["AWS_ENDPOINT"] && active_storage_tables_installed?
    puts "\n== Ensuring Minio bucket exists =="
    require_relative "../config/environment"
    require "aws-sdk-s3"
    s3 = Aws::S3::Client.new(
      endpoint: ENV.fetch("AWS_ENDPOINT"),
      access_key_id: ENV.fetch("AWS_ACCESS_KEY_ID"),
      secret_access_key: ENV.fetch("AWS_SECRET_ACCESS_KEY"),
      region: ENV.fetch("AWS_REGION", "us-east-1"),
      force_path_style: true,
    )
    bucket = ENV.fetch("AWS_BUCKET", "fibe-rails")
    begin
      s3.head_bucket(bucket: bucket)
      puts "Bucket #{bucket} already exists."
    rescue Aws::S3::Errors::NotFound, Aws::S3::Errors::Http404Error
      s3.create_bucket(bucket: bucket)
      puts "Bucket #{bucket} created."
    rescue Aws::Errors::ServiceError => e
      puts "Skipping Minio bucket setup: #{e.message}"
    end
  elsif ENV["AWS_ENDPOINT"]
    puts "\n== Skipping Minio bucket setup =="
    puts "Active Storage tables are not installed. Run bin/rails active_storage:install when the app needs file uploads."
  end

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush
    exec "bin/dev"
  end
end
