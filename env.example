# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info
WEB_CONCURRENCY=0
PORT=3000
PIDFILE=true

# Database (Postgres direct, no PgBouncer)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=fibe_rails
DB_DIRECT_HOST=localhost
DB_DIRECT_PORT=5432

# Cache + jobs + ActionCable + Rack::Attack store
REDIS_URL=redis://localhost:6379/1

# Active Storage (Minio S3-compatible — port 9000, NOT 4566)
STORAGE_SERVICE=amazon
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniopassword
AWS_REGION=us-east-1
AWS_BUCKET=fibe-rails
AWS_ENDPOINT=http://localhost:9000

# Iframe / cross-site cookie config
# In dev (HTTP localhost) keep these at the defaults below. In production the
# playground is HTTPS and likely embedded inside fibe.gg — switch to:
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# CORS — comma-separated origins, or "*" for permissive. Credentials are only
# attached when origin is *not* "*".
CORS_ALLOWED_ORIGINS=*

# CSP — "off" (no header), "report-only", or "enforce"
CSP_MODE=off
# Space-separated list. "*" means "allow being framed by anyone".
FRAME_ANCESTORS=*

# Production-only host allow-list
ALLOWED_HOSTS=

# Sidekiq Web (production only — dev mount is unauthenticated)
SIDEKIQ_USER=admin
SIDEKIQ_PASSWORD=admin

# Testing
SILENT_TESTS=
EXAMPLE_TIMEOUT=60
ENABLE_RACK_ATTACK=0
